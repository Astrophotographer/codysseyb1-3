      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst items = $input.all();\n\nfunction rowNumber(item, index) {\n  const j = item.json || {};\n  const candidates = [j.row_number, j.rowNumber, j.__rowNumber, j['row_number'], j['Row Number']];\n  for (const value of candidates) {\n    const n = Number(value);\n    if (Number.isFinite(n) && n > 0) return n;\n  }\n  // Google Sheets header row is row 1, so first data row is usually row 2\n  return index + 2;\n}\n\nconst rows = items.map((item, index) => ({ item, row: rowNumber(item, index) }));\nconst maxRow = rows.reduce((max, r) => Math.max(max, r.row), 0);\n\n// First scheduled run: remember the current end of the response sheet so old rows are not duplicated.\nif (staticData.project1LastProcessedRow === undefined) {\n  staticData.project1LastProcessedRow = maxRow;\n  return [];\n}\n\nconst lastProcessed = Number(staticData.project1LastProcessedRow || 0);\nconst freshRows = rows\n  .filter(r => r.row > lastProcessed)\n  .sort((a, b) => a.row - b.row);\n\nif (freshRows.length === 0) {\n  return [];\n}\n\nstaticData.project1LastProcessedRow = freshRows[freshRows.length - 1].row;\nreturn freshRows.map(r => ({\n  json: {\n    ...r.item.json,\n    원본행번호: r.row,\n  },\n}));"
      },
